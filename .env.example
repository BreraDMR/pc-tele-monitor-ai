# Telegram Bot Token (get it from @BotFather)
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# Admin Telegram ID (to manage registrations/access, get it from @userinfobot)
ADMIN_TELEGRAM_ID=YOUR_TELEGRAM_ID

# Ollama Endpoint URL (variable name must match monitor.py / README)
OLLAMA_URL=http://host.docker.internal:11434

# Disk monitoring path. Inside the container this is the container's own filesystem.
# To monitor a host drive, mount it as a volume in docker-compose.yml and point here.
MONITOR_DISK_PATH=/

# Optional: if running inside Docker and you mount the host /proc, tell psutil where to look.
# Leave unset to use the container's own /proc.
# PROCFS_PATH=/host/proc
