# Telegram Bot Token (get it from @BotFather)
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# Admin Telegram IDs, comma-separated (to manage registrations/access, get from @userinfobot).
# Supports multiple admins, e.g. ADMIN_TELEGRAM_IDS=111111,222222
# Legacy single ADMIN_TELEGRAM_ID is still supported as a fallback if this is unset.
ADMIN_TELEGRAM_IDS=YOUR_TELEGRAM_ID

# Whisper model size used to transcribe voice messages (tiny/base/small/medium).
# Bigger = more accurate but slower and a larger download on first use.
WHISPER_MODEL_SIZE=base

# Ollama Endpoint URL (variable name must match monitor.py / README)
OLLAMA_URL=http://host.docker.internal:11434

# Disk monitoring path. Inside the container this is the container's own filesystem.
# To monitor a host drive, mount it as a volume in docker-compose.yml and point here.
MONITOR_DISK_PATH=/

# Optional: if running inside Docker and you mount the host /proc, tell psutil where to look.
# Leave unset to use the container's own /proc.
# PROCFS_PATH=/host/proc
