# Telegram Bot Token (get it from @BotFather)
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# Admin Telegram ID (to manage registrations/access, get it from @userinfobot)
ADMIN_TELEGRAM_ID=YOUR_TELEGRAM_ID

# Ollama Endpoint URL
OLLAMA_API_URL=YOUR_LLM_API_URL

# Disk monitoring path (on Windows/Docker, we mount C: drive to /host_c)
MONITOR_DISK_PATH=/host_c

# If running inside Docker and we want to monitor the host WSL2/Linux metrics via procfs mount
# Setting this tells psutil where to look for host metrics instead of container's own /proc
PROCFS_PATH=/host/proc
